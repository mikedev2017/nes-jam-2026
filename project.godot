; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="NES Jam 2026"
run/main_scene="uid://curtma6o4rtp"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/textures/icon.svg"

[autoload]

InventorySystem="*uid://d3kqxcc7mp2et"
SceneLoader="*uid://yesiyfnqo7xw"
GameManager="*uid://dlvidqjyxnlo"

[display]

window/size/viewport_width=256
window/size/viewport_height=240
window/size/window_width_override=768
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_state_charts/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://assets/": "red",
"res://concept_art/": "blue",
"res://levels/": "green",
"res://resources/": "purple",
"res://scenes/": "yellow"
}

[global_group]

player="Player group"
player_attack="Attacks from the Player"

